{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An item for sale in the store.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "stock": { "type": "number" },
        "lowStockThreshold": { "type": "number" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "shippingAddress": { "type": "object" },
        "paymentMethod": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "isResellerOrder": { "type": "boolean" },
        "commissionAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalAmount", "status"]
    },
    "User": {
      "title": "User",
      "description": "A platform user (customer, admin, or reseller).",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin", "reseller"] },
        "points": { "type": "number" },
        "commissionBalance": { "type": "number" },
        "addresses": { "type": "array" },
        "wishlist": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Review": {
      "title": "Review",
      "description": "Product review and rating.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": "Product",
      "description": "Store products."
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders."
    },
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles and settings."
    },
    "reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews."
    }
  }
}
